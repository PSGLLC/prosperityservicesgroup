---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT, COMPLIANCE } from '../site.config';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Prosperity Services Group LLC',
    url: 'https://prosperityservicesgroup.com/contact',
    telephone: '+1-866-648-1578',
    email: 'kayla@priceservicesgroup.com',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I schedule a consultation?',
        acceptedAnswer: { '@type': 'Answer', text: 'Call or email us using the contact details on this page, or fill out the message form and we\'ll reach out to schedule a free, no-pressure consultation.' },
      },
      {
        '@type': 'Question',
        name: 'How quickly will I get a response?',
        acceptedAnswer: { '@type': 'Answer', text: 'We typically respond to messages within one business day.' },
      },
      {
        '@type': 'Question',
        name: 'Is there any cost or obligation to talk with an agent?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Consultations are free and educational, with no obligation to purchase any insurance product.' },
      },
      {
        '@type': 'Question',
        name: 'What can I ask about during a consultation?',
        acceptedAnswer: { '@type': 'Answer', text: 'You\'re welcome to ask about annuities, safe money strategies, income planning, or any other retirement savings question — a licensed independent agent will walk through your options.' },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://prosperityservicesgroup.com/' },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://prosperityservicesgroup.com/contact' },
    ],
  },
];
---
<BaseLayout
  title="Contact Us | Prosperity Services Group"
  description="Get in touch with Prosperity Services Group about fixed indexed annuities, safe money strategies, and lifetime income planning."
  path="/contact"
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow eyebrow-gold">Contact</p>
      <h1>Let's Talk About Your Retirement</h1>
      <p class="subhead">
        Reach out with questions about annuities, safe money strategies, or income planning —
        we're happy to help.
      </p>
      <div class="contact-details">
        <a href={CONTACT.phoneHref} class="contact-item">{CONTACT.phone}</a>
        <a href={`mailto:${CONTACT.email}`} class="contact-item">{CONTACT.email}</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container contact-grid">
      <div class="card">
        <h2>Send Us a Message</h2>
        <form id="contact-lead-form" class="lead-form" novalidate>
          <div class="form-row">
            <label for="name">Name <span aria-hidden="true">*</span></label>
            <input type="text" id="name" name="name" autocomplete="name" required />
          </div>
          <div class="form-row">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" autocomplete="email" required />
          </div>
          <div class="form-row">
            <label for="phone">Phone <span class="optional">(optional)</span></label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" />
          </div>
          <div class="form-row">
            <label for="message">Message <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <!-- Honeypot — hidden from real visitors -->
          <div class="hp-field" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <button type="submit" class="btn btn-gold form-submit">Send Message</button>
          <p id="contact-form-error" class="form-error" role="alert" hidden></p>
        </form>

        <div id="contact-form-success" class="form-success" hidden>
          <p>Thanks for reaching out — we'll be in touch soon!</p>
        </div>

        <p class="compliance-note">
          By submitting this form you agree to be contacted by Price Services Group LLC.
          We respect your privacy and will never sell your information.
        </p>
      </div>

      <div class="card card-gold info-card">
        <h2>Reach Us Directly</h2>
        <p><strong>Phone:</strong> <a href={CONTACT.phoneHref}>{CONTACT.phone}</a></p>
        <p><strong>Email:</strong> <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></p>
        <p><strong>Licensed in:</strong> {COMPLIANCE.states.join(', ')}</p>
        <div class="disclaimer">
          {COMPLIANCE.annuityDisclaimer}
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-lead-form') as HTMLFormElement | null;
    const errorEl = document.getElementById('contact-form-error');
    const successEl = document.getElementById('contact-form-success');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (errorEl) {
        errorEl.hidden = true;
        errorEl.textContent = '';
      }

      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') ?? '').trim(),
        email: String(formData.get('email') ?? '').trim(),
        phone: String(formData.get('phone') ?? '').trim(),
        message: String(formData.get('message') ?? '').trim(),
        website: String(formData.get('website') ?? ''),
        pagePath: window.location.pathname,
      };

      const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }

      try {
        const res = await fetch('/api/contact-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({ ok: false }));

        if (res.ok && data.ok) {
          form.hidden = true;
          if (successEl) successEl.hidden = false;
        } else {
          throw new Error(data.error || 'Something went wrong. Please try again.');
        }
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
          errorEl.hidden = false;
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      }
    });
  </script>
</BaseLayout>

<style>
  .page-hero { background: var(--color-lavender); padding: 4rem 0; }
  :root[data-theme="dark"] .page-hero { background: var(--color-bg-alt); }
  .subhead { color: var(--color-text-muted); font-size: 1.1rem; max-width: 640px; margin-bottom: 1.5rem; }
  .contact-details { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .contact-item {
    font-weight: 700;
    color: var(--color-purple);
    text-decoration: none;
    font-size: 1.05rem;
  }
  :root[data-theme="dark"] .contact-item { color: var(--color-teal); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 800px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  .info-card p { margin-bottom: 0.75rem; }
  .info-card .disclaimer { margin-top: 1.5rem; }

  .lead-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: flex; flex-direction: column; gap: 0.35rem; text-align: left; }
  .form-row label { font-weight: 600; font-size: 0.9rem; color: var(--color-text); }
  .form-row .optional { font-weight: 400; color: var(--color-text-muted); font-size: 0.8rem; }
  .form-row input, .form-row textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    resize: vertical;
  }
  .form-row input:focus, .form-row textarea:focus {
    outline: none;
    border-color: var(--color-purple);
    box-shadow: 0 0 0 3px rgba(144, 89, 181, 0.18);
  }
  :root[data-theme="dark"] .form-row input:focus,
  :root[data-theme="dark"] .form-row textarea:focus {
    border-color: var(--color-teal);
    box-shadow: 0 0 0 3px rgba(81, 222, 204, 0.18);
  }
  .hp-field { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .form-submit { width: 100%; text-align: center; margin-top: 0.25rem; }
  .form-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
  .form-error { color: #b3261e; font-size: 0.9rem; margin: 0; }
  .form-success {
    background: var(--color-lavender);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: center;
    font-weight: 600;
    color: var(--color-text);
  }
  :root[data-theme="dark"] .form-success { background: rgba(81, 222, 204, 0.12); }
  .compliance-note {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    margin: 1.25rem 0 0;
    text-align: center;
  }
</style>
