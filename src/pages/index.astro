---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOKING_URL, COMPLIANCE } from '../site.config';

const topics = [
  { href: '/annuities', title: 'Fixed Indexed Annuities', desc: 'What they are, how they work, and the growth and income features they can offer.' },
  { href: '/safe-money', title: 'Safe Money Strategies', desc: 'Protecting your retirement savings from market downturns and sequence of returns risk.' },
  { href: '/income', title: 'Lifetime Income Planning', desc: 'Turning your savings into a reliable, guaranteed stream of retirement income.' },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'FinancialService',
    name: 'Prosperity Services Group LLC',
    url: 'https://prosperityservicesgroup.com',
    description: 'Independent guidance on fixed indexed annuities, safe money strategies, and lifetime income planning.',
    telephone: '+1-866-648-1578',
    email: 'kayla@priceservicesgroup.com',
    areaServed: COMPLIANCE.states,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Prosperity Services Group LLC',
    url: 'https://prosperityservicesgroup.com',
    telephone: '+1-866-648-1578',
    email: 'kayla@priceservicesgroup.com',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Kayla Price',
    jobTitle: 'Licensed Independent Insurance Agent',
    identifier: 'NPN 18530055',
    worksFor: {
      '@type': 'Organization',
      name: 'Prosperity Services Group LLC',
    },
  },
];
---
<BaseLayout
  title="Secure Your Financial Future | Prosperity Services Group"
  description="Independent guidance on fixed indexed annuities, safe money strategies, and lifetime income planning — protect your retirement savings and build guaranteed income."
  path="/"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow eyebrow-gold">Retirement &amp; Annuity Planning</p>
      <h1>Secure Your Financial Future</h1>
      <p class="subhead">
        Fixed indexed annuities and safe money strategies can help protect what you've worked hard
        to build while giving your retirement savings room to grow. Get independent, plain-English
        guidance built around your goals — not a sales pitch.
      </p>
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-gold">Schedule a Consultation</a>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">Explore</p>
      <h2>Understand your options before you decide</h2>
      <div class="grid grid-3">
        {topics.map((t) => (
          <a href={t.href} class="card card-gold topic-card">
            <h3>{t.title}</h3>
            <p>{t.desc}</p>
            <span class="learn-more">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container meet-kayla">
      <img src="/img/headshot.png" alt="Kayla, licensed independent insurance agent" class="headshot" />
      <div class="card kayla-card">
        <p class="eyebrow">Meet Kayla</p>
        <h2>Your guide to safe, steady retirement planning</h2>
        <p>
          Kayla is a licensed independent insurance agent (NPN 18530055) who helps people
          understand how fixed indexed annuities and safe money strategies fit into their
          retirement plan — in plain English, without pressure or a sales pitch.
        </p>
        <p>
          Because she isn't tied to a single insurance company, her focus stays on your goals —
          protecting your principal, growing your savings, and creating income you can't outlive.
        </p>
        <p>
          Want a written overview first? Request our <a href="/guide">free PSG Annuity Guide</a>,
          or <a href="/contact">get in touch</a> with any questions.
        </p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Ready to talk about your retirement?</h2>
      <p>Schedule a free, no-pressure consultation with a licensed independent agent.</p>
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-teal">Schedule a Consultation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-dark) 0%, #2b1147 100%);
    color: #fff;
    padding: 6rem 0;
  }
  .hero-inner { max-width: 700px; }
  .hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3.2rem); }
  .subhead { font-size: 1.15rem; color: #e2d4f0; margin-bottom: 1.75rem; }

  .topic-card { text-decoration: none; display: block; transition: transform 0.15s ease; }
  .topic-card:hover { transform: translateY(-4px); }
  .topic-card h3 { font-size: 1.15rem; margin-bottom: 0.4rem; }
  .topic-card p { color: var(--color-text-muted); font-size: 0.92rem; margin: 0 0 0.75rem; }
  .learn-more { color: var(--color-purple); font-weight: 700; font-size: 0.85rem; }

  .meet-kayla {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .headshot {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .kayla-card p:last-child { margin-bottom: 0; }
  @media (max-width: 800px) {
    .meet-kayla { grid-template-columns: 1fr; }
    .headshot { max-width: 260px; margin: 0 auto; }
  }

  .cta-section {
    background: var(--color-purple);
    color: #fff;
    text-align: center;
  }
  .cta-inner h2 { color: #fff; }
  .cta-inner p { color: #f0e6f8; margin-bottom: 1.5rem; }
</style>
