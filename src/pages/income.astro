---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOKING_URL, COMPLIANCE } from '../site.config';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Lifetime Income Planning',
    description: 'Learn how to turn retirement savings into guaranteed lifetime income, including how income riders on fixed indexed annuities work.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is an income rider?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'An income rider is an optional add-on available on many fixed indexed annuity contracts, typically for an additional cost, that guarantees a stream of income for life once you begin taking withdrawals.',
        },
      },
      {
        '@type': 'Question',
        name: 'Why does guaranteed income matter in retirement?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Social Security and, for some, a pension provide a foundation of guaranteed income, but for many people that foundation is not enough to cover all expenses. Guaranteed income sources help ensure you do not outlive your savings.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can an income rider run out?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Unlike simply withdrawing from a regular savings account, an income rider is backed by the insurance company\'s guarantee, so income payments are designed to continue for your lifetime even if the underlying account value is drawn down to zero.',
        },
      },
      {
        '@type': 'Question',
        name: 'How do fixed indexed annuities support an income plan?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Fixed indexed annuities combine principal protection, so money set aside for future income is not exposed to market losses, with the option to add an income rider that converts that protected value into a guaranteed paycheck for life.',
        },
      },
      {
        '@type': 'Question',
        name: 'How do I build an income plan?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The right income strategy depends on your full financial picture, including your other savings, Social Security timing, expenses, and goals. A licensed advisor can help you map out where guaranteed income fits.',
        },
      },
    ],
  },
];
---
<BaseLayout
  title="Lifetime Income Planning | Prosperity Services Group"
  description="Turn your retirement savings into guaranteed income. Learn how income riders on fixed indexed annuities can provide income you cannot outlive."
  path="/income"
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow eyebrow-gold">Income Planning</p>
      <h1>Turning Savings Into Lifetime Income</h1>
      <p class="subhead">
        One of the biggest shifts in retirement is moving from saving money to spending it.
        Lifetime income planning is about making sure that shift doesn't put your financial
        security at risk.
      </p>
    </div>
  </section>

  <section>
    <div class="container narrow">
      <h2>Why guaranteed income matters</h2>
      <p>
        Social Security and, for some, a pension provide a foundation of guaranteed income in
        retirement. But for many people, that foundation isn't enough to cover all of their
        expenses. The question becomes: how do you generate additional income you can count on,
        month after month, for as long as you live — without worrying about outliving your
        savings?
      </p>

      <h2>What is an income rider?</h2>
      <div class="callout-gold">
        <p style="margin-bottom:0;">
          An income rider is an optional add-on available on many fixed indexed annuity contracts,
          typically for an additional cost or fee. It guarantees a stream of income for life, often
          based on a percentage of your contract's benefit base, once you begin taking withdrawals.
          Unlike simply withdrawing money from a regular savings account — which can run out — an
          income rider is backed by the insurance company's guarantee, meaning the income payments
          are designed to continue for your lifetime, even if your underlying account value is
          eventually drawn down to zero.
        </p>
      </div>

      <h2>How FIAs can support an income plan</h2>
      <p>
        Fixed indexed annuities are often used as a building block for lifetime income planning
        because they combine two things: principal protection, so the money set aside for future
        income isn't exposed to market losses, and the option to add an income rider, which
        converts that protected value into a guaranteed paycheck for life. To understand how the
        underlying product works, visit our <a href="/annuities">Fixed Indexed Annuities</a> page,
        or see how this fits into a broader approach on our <a href="/safe-money">Safe Money</a> page.
      </p>

      <h2>Building your income plan</h2>
      <p>
        The right income strategy depends on your full financial picture — your other savings,
        Social Security timing, expenses, and goals. A licensed advisor can help you map out where
        guaranteed income fits alongside your other retirement assets. Prefer to start with a
        written overview? Request our <a href="/guide">free Safe Money Guide</a>, or
        <a href="/contact">get in touch</a> with any questions.
      </p>

      <div class="disclaimer">
        {COMPLIANCE.annuityDisclaimer}
      </div>
    </div>
  </section>

  <section class="section-alt cta-band">
    <div class="container cta-inner">
      <h2>Ready to map out your income plan?</h2>
      <p>Schedule a free, no-pressure consultation with a licensed independent advisor.</p>
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-gold">Schedule a Consultation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { background: var(--color-lavender); padding: 4rem 0; }
  :root[data-theme="dark"] .page-hero { background: var(--color-bg-alt); }
  .subhead { color: var(--color-text-muted); font-size: 1.1rem; max-width: 700px; margin-bottom: 0; }
  .narrow { max-width: 820px; }
  .cta-band { text-align: center; }
  .cta-inner p { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .disclaimer { margin-top: 2rem; }
</style>
